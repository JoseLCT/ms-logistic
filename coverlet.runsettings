<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>opencover,cobertura</Format>

          <!-- Exclude assemblies entirely -->
          <Exclude>
            [*]*.Migrations.*,
            [*.Migrations]*,
            [MsLogistic.UnitTest]*,
            [MsLogistic.IntegrationTest]*
          </Exclude>

          <!-- Exclude specific namespaces / classes -->
          <ExcludeByFile>
            **/Migrations/**/*.cs,
            **/PersistenceModel/**/*.cs,
            **/Configurations/*Configuration.cs,
            **/Program.cs,
            **/DependencyInjection.cs,
            **/*Extensions.cs
          </ExcludeByFile>

          <!-- Exclude code marked with attributes -->
          <ExcludeByAttribute>
            Obsolete,
            GeneratedCodeAttribute,
            CompilerGeneratedAttribute,
            ExcludeFromCodeCoverageAttribute
          </ExcludeByAttribute>

          <!-- Don't count auto-generated source generator output -->
          <SkipAutoProps>true</SkipAutoProps>

          <!-- UseSourceLink generates URI-based paths instead of filesystem paths.
               SonarCloud cannot correlate coverage when paths don't match source files.
               Keep this disabled for CI coverage reporting. -->
          <UseSourceLink>false</UseSourceLink>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
